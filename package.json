{
  "name": "blazecode",
  "version": "0.1.0",
  "description": "Terminal AI coding agent for BlazeAPI Premium models",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/wix/blazecode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wix/blazecode.git"
  },
  "bugs": {
    "url": "https://github.com/wix/blazecode/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-agent",
    "blazeapi",
    "agent",
    "tui",
    "llm",
    "mcp"
  ],
  "bin": {
    "blaze": "./dist/cli.js"
  },
  "exports": {
